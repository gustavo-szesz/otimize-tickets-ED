{
  "manifest_version": 3,
  "name": "HubSpot Help Desk - Observação Interna",
  "version": "1.0.0",
  "description": "Extensão interna para captura passiva de dados visíveis no HubSpot Help Desk e cópia de observação padronizada.",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage"],
  "host_permissions": ["https://app.hubspot.com/help-desk/*"],
  "icons": {
    "16": "images/logo-preenchido-isotipo-magenta-09.png",
    "32": "images/logo-preenchido-isotipo-magenta-09.png",
    "48": "images/logo-preenchido-isotipo-magenta-09.png",
    "128": "images/logo-preenchido-isotipo-magenta-09.png"
  },
  "action": {
    "default_title": "Observação HubSpot",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/logo-preenchido-isotipo-magenta-09.png",
      "32": "images/logo-preenchido-isotipo-magenta-09.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://app.hubspot.com/help-desk/*"],
      "js": [
        "content/constants.js",
        "content/dom-utils.js",
        "content/ticket-extractor.js",
        "content/orgid-extractor.js",
        "content/message-handler.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
